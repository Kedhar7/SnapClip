<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- High Contrast theme uses SystemColors for accessibility compliance.
         All colors reference system-defined resources to respect user's OS contrast settings. -->

    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackground" Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="{x:Static SystemColors.ControlColor}"/>
    <SolidColorBrush x:Key="CardBackground" Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="HoverBackground" Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="SelectedBackground" Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="SearchBarBackground" Color="{x:Static SystemColors.WindowColor}"/>

    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryText" Color="{x:Static SystemColors.WindowTextColor}"/>
    <SolidColorBrush x:Key="SecondaryText" Color="{x:Static SystemColors.GrayTextColor}"/>
    <SolidColorBrush x:Key="PlaceholderText" Color="{x:Static SystemColors.GrayTextColor}"/>
    <SolidColorBrush x:Key="AccentText" Color="{x:Static SystemColors.HotTrackColor}"/>

    <!-- Border Colors -->
    <SolidColorBrush x:Key="BorderBrush" Color="{x:Static SystemColors.ActiveBorderColor}"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{x:Static SystemColors.ActiveBorderColor}"/>

    <!-- Accent Colors -->
    <SolidColorBrush x:Key="AccentBrush" Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF0000"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#00FF00"/>

    <!-- Pin/Favorite Indicators -->
    <SolidColorBrush x:Key="PinnedBrush" Color="{x:Static SystemColors.HotTrackColor}"/>
    <SolidColorBrush x:Key="FavoriteBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="EncryptedBrush" Color="#00FF00"/>

    <!-- Status Bar -->
    <SolidColorBrush x:Key="StatusBarBackground" Color="{x:Static SystemColors.ControlColor}"/>
    <SolidColorBrush x:Key="StatusBarText" Color="{x:Static SystemColors.ControlTextColor}"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollBarThumb" Color="{x:Static SystemColors.ScrollBarColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrack" Color="{x:Static SystemColors.ControlColor}"/>

</ResourceDictionary>
