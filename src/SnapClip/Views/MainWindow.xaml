<Window x:Class="SnapClip.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SnapClip.ViewModels"
        xmlns:converters="clr-namespace:SnapClip.Converters"
        xmlns:models="clr-namespace:SnapClip.Models"
        mc:Ignorable="d"
        Title="SnapClip"
        Width="420" Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        AutomationProperties.Name="SnapClip Clipboard Manager"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ClipTypeToIconConverter x:Key="ClipTypeToIcon"/>
        <converters:TimestampToRelativeConverter x:Key="TimestampToRelative"/>

        <!-- Text Clip Template -->
        <DataTemplate x:Key="TextClipTemplate" DataType="{x:Type vm:ClipItemViewModel}">
            <Grid Margin="8,4" Cursor="Hand">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Type Icon -->
                <TextBlock Grid.Column="0" Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                           FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource SecondaryText}"
                           AutomationProperties.Name="Text clip"/>

                <!-- Content Preview -->
                <TextBlock Grid.Column="1" Text="{Binding Preview}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" Foreground="{DynamicResource PrimaryText}"
                           FontSize="13" MaxHeight="40"/>

                <!-- Timestamp + Status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{DynamicResource PinnedBrush}" Margin="0,0,4,0"
                               Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"
                               AutomationProperties.Name="Pinned"
                               ToolTip="Pinned"/>
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{DynamicResource EncryptedBrush}" Margin="0,0,4,0"
                               Visibility="{Binding IsEncrypted, Converter={StaticResource BoolToVis}}"
                               AutomationProperties.Name="Encrypted"
                               ToolTip="Encrypted"/>
                    <TextBlock Text="{Binding RelativeTime}" Foreground="{DynamicResource SecondaryText}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Image Clip Template -->
        <DataTemplate x:Key="ImageClipTemplate" DataType="{x:Type vm:ClipItemViewModel}">
            <Grid Margin="8,4" Cursor="Hand">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Thumbnail -->
                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0">
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                           AutomationProperties.Name="{Binding Preview}"/>
                </Border>

                <!-- Description -->
                <TextBlock Grid.Column="1" Text="{Binding Preview}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" Foreground="{DynamicResource PrimaryText}" FontSize="13"/>

                <!-- Timestamp -->
                <TextBlock Grid.Column="2" Text="{Binding RelativeTime}"
                           Foreground="{DynamicResource SecondaryText}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
        </DataTemplate>

        <!-- File Clip Template -->
        <DataTemplate x:Key="FileClipTemplate" DataType="{x:Type vm:ClipItemViewModel}">
            <Grid Margin="8,4" Cursor="Hand">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets"
                           FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource SecondaryText}"
                           AutomationProperties.Name="File clip"/>

                <TextBlock Grid.Column="1" Text="{Binding Preview}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" Foreground="{DynamicResource PrimaryText}" FontSize="13"/>

                <TextBlock Grid.Column="2" Text="{Binding RelativeTime}"
                           Foreground="{DynamicResource SecondaryText}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
        </DataTemplate>

        <!-- Template Selector for clip types -->
        <converters:ClipTemplateSelector x:Key="ClipTemplateSelector"
                                         TextTemplate="{StaticResource TextClipTemplate}"
                                         ImageTemplate="{StaticResource ImageClipTemplate}"
                                         FileTemplate="{StaticResource FileClipTemplate}"/>
    </Window.Resources>

    <!-- Main Container with rounded corners and shadow -->
    <Border CornerRadius="8" Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Search bar -->
                <RowDefinition Height="Auto"/>   <!-- Pinned section -->
                <RowDefinition Height="*"/>      <!-- Recent clips -->
                <RowDefinition Height="Auto"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- Search Bar -->
            <Border Grid.Row="0" Background="{DynamicResource SearchBarBackground}"
                    CornerRadius="8,8,0,0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search icon -->
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource SecondaryText}"/>

                    <!-- Search TextBox -->
                    <TextBox Grid.Column="1" x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource PrimaryText}" FontSize="14"
                             VerticalAlignment="Center"
                             AutomationProperties.Name="Search clips"
                             AutomationProperties.HelpText="Type to filter clipboard history"/>

                    <!-- Settings button -->
                    <Button Grid.Column="2" x:Name="SettingsButton" Click="SettingsButton_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Padding="8,4" Margin="4,0"
                            AutomationProperties.Name="Settings"
                            ToolTip="Settings">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource SecondaryText}"/>
                    </Button>

                    <!-- Insights button -->
                    <Button Grid.Column="3" x:Name="InsightsButton" Click="InsightsButton_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Padding="8,4"
                            AutomationProperties.Name="Usage Insights"
                            ToolTip="Usage Insights">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource SecondaryText}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Pinned Section -->
            <Border Grid.Row="1" Padding="8,4"
                    Visibility="{Binding PinnedClips.Count, Converter={StaticResource BoolToVis}}"
                    BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="&#xE718; Pinned" FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource PinnedBrush}" FontSize="11"
                               FontWeight="SemiBold" Margin="8,4,0,4"
                               AutomationProperties.Name="Pinned clips section"/>

                    <ItemsControl ItemsSource="{Binding PinnedClips}"
                                  AutomationProperties.Name="Pinned clips list"
                                  AutomationProperties.LiveSetting="Polite">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonUp="ClipItem_Click"
                                        Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Unpin" Command="{Binding DataContext.PinClipCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <MenuItem Header="Delete" Command="{Binding DataContext.DeleteClipCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <MenuItem Header="Copy" Click="CopyClip_Click" Tag="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <ContentPresenter Content="{Binding}"
                                                      ContentTemplateSelector="{StaticResource ClipTemplateSelector}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Recent Clips -->
            <Grid Grid.Row="2">
                <StackPanel>
                    <TextBlock Text="Recent" Foreground="{DynamicResource SecondaryText}"
                               FontSize="11" FontWeight="SemiBold" Margin="16,8,0,4"
                               AutomationProperties.Name="Recent clips section"/>

                    <ListBox x:Name="ClipListBox"
                             ItemsSource="{Binding RecentClips}"
                             SelectedItem="{Binding SelectedClip}"
                             Background="Transparent" BorderThickness="0"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             KeyDown="ClipListBox_KeyDown"
                             AutomationProperties.Name="Clipboard history list"
                             AutomationProperties.LiveSetting="Polite">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="FocusVisualStyle">
                                    <Setter.Value>
                                        <Style>
                                            <Setter Property="Control.Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <Border BorderBrush="{DynamicResource FocusBorderBrush}"
                                                                BorderThickness="2" CornerRadius="2"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" Padding="4,2">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Pin" Command="{Binding DataContext.PinClipCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                        <MenuItem Header="Favorite" Command="{Binding DataContext.FavoriteClipCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Delete" Command="{Binding DataContext.DeleteClipCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" InputGestureText="Del"/>
                                                        <MenuItem Header="Copy" Click="CopyClip_Click" Tag="{Binding}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Mark as Sensitive" Click="MarkSensitive_Click" Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource HoverBackground}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource SelectedBackground}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplateSelector>
                            <converters:ClipTemplateSelector
                                TextTemplate="{StaticResource TextClipTemplate}"
                                ImageTemplate="{StaticResource ImageClipTemplate}"
                                FileTemplate="{StaticResource FileClipTemplate}"/>
                        </ListBox.ItemTemplateSelector>
                    </ListBox>
                </StackPanel>

                <!-- Empty state -->
                <TextBlock Text="No clips captured yet. Copy something to get started!"
                           Foreground="{DynamicResource PlaceholderText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Margin="20"
                           Visibility="{Binding RecentClips.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                           AutomationProperties.Name="No clips captured"/>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="3" Background="{DynamicResource StatusBarBackground}"
                    CornerRadius="0,0,8,8" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               Foreground="{DynamicResource StatusBarText}" FontSize="11"
                               AutomationProperties.Name="{Binding StatusText}"/>

                    <TextBlock Grid.Column="1"
                               Foreground="{DynamicResource StatusBarText}" FontSize="11">
                        <Run Text="Total pastes: "/><Run Text="{Binding TotalPastes, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
